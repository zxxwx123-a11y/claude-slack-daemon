# claude-slack-daemon secrets — copy to .env (which is .gitignore'd). Never commit real tokens.
# How to get these: create a Slack app from slack-app-manifest.yaml, then:
#   - SLACK_APP_TOKEN: Basic Information -> App-Level Tokens -> Generate (scope: connections:write)
#   - SLACK_BOT_TOKEN: Install App -> Install to Workspace -> copy "Bot User OAuth Token"
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

# --- Optional: only for the proactive features (digest.py / draft.py) ---
# SLACK_USER_TOKEN: a User OAuth Token with search:read (+ channels:history, groups:history).
#   Minted on install when the manifest requests user scopes ("User OAuth Token" on the Install page).
SLACK_USER_TOKEN=
# Gmail (digest only): an app password, NOT your normal password.
#   Google Account -> Security -> 2-Step Verification -> App passwords.
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
